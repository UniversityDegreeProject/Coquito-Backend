// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
//* MODELOS DE AUTENTICACIÓN Y USUARIOS
// ============================================

enum UserRole {
  Administrador  
  Vendedor
}

enum UserStatus {
  Activo      
  Inactivo    
  Suspendido  
}

model User {
  id            String     @id @default(uuid())
  username      String     @unique
  email         String     @unique
  emailVerified Boolean    @default(false) @map("email_verified") 
  password      String     
  firstName     String     @map("first_name")
  lastName      String     @map("last_name")
  phone         String?
  role          UserRole   @default(Vendedor) @map("role")
  status        UserStatus @default(Activo)
  refreshToken  String?    @map("refresh_token") @db.Text 
  
  // Relaciones
  sales           Sale[]          
  cashRegisters   CashRegister[]   
  stockMovements  StockMovement[]  
  activityLogs    ActivityLog[]    
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  lastConnection DateTime? @map("last_connection")
  
  @@map("users")
}

// ============================================
// MODELOS DE CATÁLOGO (Productos y Categorías)
// ============================================

enum CategoryStatus {
  Activo
  Inactivo
}

model Category {
  id          String         @id @default(uuid())
  name        String         @unique
  description String?
  status      CategoryStatus @default(Activo)
  
  // Relaciones
  products    Product[]
  
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@map("categories")
}

enum ProductStatus {
  Disponible    
  SinStock      
  Descontinuado 
}

model Product {
  id          String        @id @default(uuid())
  name        String
  description String?
  price       Decimal       @db.Decimal(10, 2) 
  sku         String?       @unique 
  stock       Int           @default(0)
  minStock    Int           @default(5) @map("min_stock") 
  image       String?       
  status      ProductStatus @default(Disponible)
  ingredients String?       @db.Text 
  
  // Campos para productos de peso variable (pechugas, piernas, etc.)
  isVariableWeight Boolean @default(false) @map("is_variable_weight")
  pricePerKg       Decimal? @db.Decimal(10, 2) @map("price_per_kg")
  
  // Fecha de vencimiento (para productos sin batches)
  expirationDate   DateTime? @map("expiration_date")
  
  // Relación con categoría
  categoryId  String   @map("category_id")
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  
  saleItems       SaleItem[] 
  stockMovements  StockMovement[]
  batches         ProductBatch[] 
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@map("products")
  @@index([categoryId])
  @@index([status])
  @@index([stock])
  @@index([isVariableWeight])
}

// ============================================
// MODELOS DE CLIENTES
// ============================================

enum CustomerType {
  Regular   
  VIP       
  Ocasional 
}

model Customer {
  id          String       @id @default(uuid())
  firstName   String       @map("first_name")
  lastName    String       @map("last_name")
  email       String?      @unique
  phone       String?
  address     String?
  password    String
  type        CustomerType @default(Regular)
  
  
  sales       Sale[]
  
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@map("customers")
}

// ============================================
// MODELOS DE INVENTARIO
// ============================================

enum StockMovementType {
  Reabastecimiento 
  Compra           
  Venta            
  Ajuste           
  Devolucion       
  Dañado           
}

model StockMovement {
  id          String   @id @default(uuid())
  
  productId   String   @map("product_id")
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  
  type        StockMovementType
  quantity    Int      
  previousStock Int    @map("previous_stock")
  newStock    Int      @map("new_stock") 
  
  reason      String? 
  reference   String? 
  notes       String? 
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@map("stock_movements")
  @@index([productId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ============================================
// MODELO DE BATCHES (Para productos de peso variable)
// ============================================

model ProductBatch {
  id          String   @id @default(uuid())
  
  productId   String   @map("product_id")
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  batchCode   String   @unique @map("batch_code")
  weight      Decimal  @db.Decimal(10, 3) 
  unitPrice   Decimal  @db.Decimal(10, 2) @map("unit_price") 
  stock       Int      @default(1) 
  expirationDate   DateTime? @map("expiration_date")
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@map("product_batches")
  @@index([productId])
  @@index([stock])
  @@index([createdAt])
}

// ============================================
// MODELOS DE ÓRDENES Y VENTAS
// ============================================

enum SaleStatus {
  Pendiente   
  Completado  
  Cancelado   
  Reembolsado 
}

enum PaymentMethod {
  Efectivo      
  Tarjeta       
  QR            
}

model Sale {
  id              String   @id @default(uuid())
  saleNumber      String   @unique @map("sale_number") 
  
  // Relaciones
  customerId      String?  @map("customer_id")
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  
  userId          String   @map("user_id") 
  user            User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  
  cashRegisterId  String?  @map("cash_register_id") 
  cashRegister    CashRegister? @relation(fields: [cashRegisterId], references: [id], onDelete: SetNull)
  
  // Items de la orden
  items           SaleItem[]
  
  // Información de la orden
  subtotal        Decimal  @db.Decimal(10, 2) 
  tax             Decimal  @db.Decimal(10, 2) @default(0) 
  total           Decimal  @db.Decimal(10, 2) 
  
  // Información de pago
  paymentMethod   PaymentMethod @map("payment_method")
  amountPaid      Decimal  @db.Decimal(10, 2) @map("amount_paid") 
  change          Decimal  @db.Decimal(10, 2) @default(0) 
  
  // Estado y notas
  status          SaleStatus @default(Pendiente)
  notes           String?     
  
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  completedAt     DateTime? @map("completed_at") 
  
  @@map("sales")
  @@index([userId])
  @@index([customerId])
  @@index([cashRegisterId])
  @@index([status])
  @@index([createdAt])
}

model SaleItem {
  id         String   @id @default(uuid())
  
  // Relaciones
  saleId     String   @map("sale_id")
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  productId  String   @map("product_id")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  
  // Información del item
  quantity   Int      // Cantidad del producto
  unitPrice  Decimal  @db.Decimal(10, 2) @map("unit_price") // Precio unitario al momento de la venta
  total      Decimal  @db.Decimal(10, 2) // quantity * unitPrice
  
  // Timestamps
  createdAt  DateTime @default(now()) @map("created_at")
  
  @@map("sale_items")
  @@index([saleId])
  @@index([productId])
}

// ============================================
// MODELOS DE CAJA Y CIERRE
// ============================================

enum CashRegisterStatus {
  Abierto 
  Cerrado 
}

model CashRegister {
  id                String             @id @default(uuid())
  
  userId            String             @map("user_id")
  user              User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  
  // Información de apertura
  openingAmount     Decimal            @db.Decimal(10, 2) @map("opening_amount")
  openedAt          DateTime           @default(now()) @map("opened_at")
  
  // Información de cierre
  closingAmount     Decimal?           @db.Decimal(10, 2) @map("closing_amount")
  expectedAmount    Decimal?           @db.Decimal(10, 2) @map("expected_amount")
  difference        Decimal?           @db.Decimal(10, 2)
  closedAt          DateTime?          @map("closed_at")
  
  // Resumen de ventas
  totalSales        Decimal            @db.Decimal(10, 2) @default(0) @map("total_sales")
  totalOrders       Int                @default(0) @map("total_orders")
  cashSales         Decimal            @db.Decimal(10, 2) @default(0) @map("cash_sales")
  cardSales         Decimal            @db.Decimal(10, 2) @default(0) @map("card_sales")
  qrSales           Decimal            @db.Decimal(10, 2) @default(0) @map("qr_sales")
  
  // Estado
  status            CashRegisterStatus @default(Abierto)
  notes             String?  // Notas del cierre
  
  // Relaciones
  sales             Sale[]
  
  // Timestamps
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  
  @@map("cash_registers")
  @@index([userId])
  @@index([status])
  @@index([openedAt])
}

// ============================================
// MODELOS DE CONFIGURACIÓN Y SISTEMA
// ============================================

model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique 
  value       String   
  description String?  
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@map("system_config")
}

model ActivityLog {
  id          String   @id @default(uuid())
  
  // Usuario que realizó la acción
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Información de la actividad
  action      String   // Acción realizada (ej: "CREATE_PRODUCT", "UPDATE_ORDER", "CLOSE_CASH_REGISTER")
  entity      String   // Entidad afectada (ej: "Product", "Order", "CashRegister")
  entityId    String?  @map("entity_id") // ID de la entidad afectada
  description String   // Descripción legible de la acción
  metadata    String?  @db.Text // Datos adicionales en formato JSON
  
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@map("activity_logs")
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}
